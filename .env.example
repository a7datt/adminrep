# ============================================
# متغيرات البيئة - مشروع الآدمن (Admin)
# لا تضع هذا الملف في Git — انسخه إلى .env
# ============================================

# ── Supabase ──────────────────────────────────
# نفس قاعدة البيانات كمشروع العملاء
VITE_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Admin JWT Secret (64+ حرف عشوائي) ─────────
# ⚠️ يجب أن يكون مختلفاً تماماً عن JWT_SECRET في مشروع العملاء
# توليد: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=CHANGE_THIS_TO_ANOTHER_DIFFERENT_RANDOM_64_CHAR_STRING

# ── CORS ──────────────────────────────────────
# أضف رابط موقع الآدمن فقط هنا
ALLOWED_ORIGINS=https://admin.yourdomain.com

# ── إعدادات السيرفر ───────────────────────────
# ⚠️ يجب أن يكون بورت مختلف عن مشروع العملاء عند التطوير المحلي
PORT=4000
NODE_ENV=production

# ── اختياري ───────────────────────────────────
# TRUST_PROXY=1
# REDIS_URL=redis://localhost:6379
